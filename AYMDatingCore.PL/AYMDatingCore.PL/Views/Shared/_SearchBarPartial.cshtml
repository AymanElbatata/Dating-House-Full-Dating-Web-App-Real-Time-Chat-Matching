    });

    radio.addEventListener("pause", () => {
        btn.innerHTML = '<i class="fa-solid fa-play"></i>';
    });

    // autoplay after first user interaction
    document.addEventListener("click", () => {
        if (!started && canPlay()) {
            radio.muted = false; // unmute on first click
