@{
    ViewData["Title"] = "Matching";
}

<style>

    .matching-page .userContainer {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 80vh;
        width: 100%;
    }

    .matching-page .matching-body {
        background: linear-gradient(to right, #ff758c, #ff7eb3);
        min-height: 80vh;
        max-width: 400px;
        width: 100%;
        margin: 0 auto;
        padding: 20px;
        display: flex;
        justify-content: center;
        align-items: center;
        position: relative;
        border-radius: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    .matching-page .matching-card {
        width: 350px;
        border-radius: 20px;
        overflow: hidden;
        background: white;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        position: relative;
        transition: transform 0.5s ease, opacity 0.5s ease;
    }

    .matching-page .matching-img {
        width: 100%;
        height: 300px;
        object-fit: cover;
    }

    .matching-page .matching-card-body {
        padding: 15px;
    }

    .matching-page .matching-buttons {
        display: flex;
        justify-content: space-around;
        margin-top: 15px;
    }

    .matching-page .matching-btn {
        border: none;
        font-size: 24px;
        padding: 10px 20px;
        border-radius: 50%;
        cursor: pointer;
        width: 60px;
        height: 60px;
        display: flex; /* 🔥 مهم */
        justify-content: center; /* 🔥 توسيط أفقي */
        align-items: center; /* 🔥 توسيط رأسي */
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .matching-page .matching-btn:hover {
            transform: scale(1.2); /* يكبر */
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

    .matching-page .matching-like {
        background: #ff4d6d;
        color: white;
    }

    .matching-page .matching-dislike {
        background: #ccc;
    }

</style>

<div class="matching-page">
    <div class="userContainer" id="userContainer"></div>
</div>
@* <h3>${user.UserName}</h3>
 *@
@section Scripts {
    <script>

        // ✅ FIX 1: منع crash لو JSON فاضي أو فيه مشكلة
        var users = [];
        try {
            users = JSON.parse('@Html.Raw(ViewBag.UsersJson ?? "[]")');
        } catch (e) {
            console.error("JSON Error:", e);
        }

        var currentIndex = 0;

        function showUser(index) {

            $('#userContainer').empty();

            if(index >= users.length){
                $('#userContainer').html(`
                    <div class="matching-body">
                        <div class="matching-card">
                            <div class="matching-card-body text-center">
                                <h3>No more profiles ❤️</h3>
                            </div>
                        </div>
                    </div>
                `);
                return;
            }

            var user = users[index];

            var displayName = (user.FirstName || '') + " " + (user.LastName || '');

            var imgUrl = user.MainImageUrl
                ? '/ImageUsers/' + user.MainImageUrl
                : '/ImageUsers/blankprofile973460.png';

            const profileUrlBase = '@Url.Action("UserProfile", "Home")';

            // ✅ FIX 2: خلى ID آمن (UserName ممكن يكسر الجيكويري)
            var safeId = index;

            var html = $(`
                <div class="matching-body">
                    <div class="matching-card" id="user-${safeId}">
                    <a href="${profileUrlBase}?UserName=${encodeURIComponent(user.UserName)}">
                         <img src="${imgUrl}" class="matching-img" />
                    </a>
                        <div class="matching-card-body text-center">
                            <h4>${displayName}</h4>
                            <h5>${user.Country}</h5>
                            <h6>${user.Purpose}</h6>
                            <p>Age: ${user.Age || '-'}</p>
                            <p>${user.ProfileHeading || ''}</p>
                            <div class="matching-buttons">
                                <button class="matching-btn matching-dislike" onclick="swipe(${safeId}, false)">❌</button>
                                <button class="matching-btn matching-like" onclick="swipe(${safeId}, true)">❤️</button>
                            </div>
                        </div>
                    </div>
                </div>
            `);

            // animation دخول
            html.find('.matching-card').css({
                opacity: 0,
                transform: 'scale(0.9)'
            });

            $('#userContainer').append(html);

            setTimeout(() => {
                html.find('.matching-card').css({
                    opacity: 1,
                    transform: 'scale(1)'
                });
            }, 50);
        }

        function swipe(id, isLike) {

            var card = $('#user-' + id);

            card.css({
                transform: 'translateX(' + (isLike ? '500px' : '-500px') + ') rotate(' + (isLike ? '30deg' : '-30deg') + ')',
                opacity: 0
            });

            var user = users[id];

            $.ajax({
                url: '@Url.Action("Swipe", "User")',
                type: 'POST',
                data: { UserName: user.UserName, isLike: isLike },
                success: function(){
                    currentIndex++;
                    setTimeout(() => showUser(currentIndex), 300);
                },
                error: function(){
                    currentIndex++;
                    setTimeout(() => showUser(currentIndex), 300);
                }
            });
        }

        $(document).ready(function(){
            showUser(currentIndex);
        });

    </script>
}
